APP_ENV=development
RELEASE_VERSION=0.2.0-rc.1
SERVICE_NAME=food-diary-app
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
JWT_SECRET=change_me
LOG_LEVEL=info
LOG_PRETTY=false
REQUEST_ID_HEADER=X-Request-ID
SHUTDOWN_TIMEOUT_MS=10000

DB_PROVIDER=sqlite
DB_PATH=./server/data/app.db
DATABASE_URL=
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nutritrack
DB_USER=nutritrack
DB_PASSWORD=nutritrack
REDIS_URL=redis://redis:6379

AUTO_MIGRATE_ON_BOOT=true
SEED_DEMO_DATA=true

DEMO_USER_EMAIL=demo@nutritrack.local
DEMO_USER_PASSWORD=Demo123!
DEMO_USER_NAME=Demo User
ADMIN_USER_EMAIL=admin@nutritrack.local
ADMIN_USER_PASSWORD=Admin123!
ADMIN_USER_NAME=System Admin
