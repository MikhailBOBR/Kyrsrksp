{
  "name": "food-diary-app",
  "version": "0.1.0",
  "private": true,
  "description": "Client-server food diary application with KБЖУ analytics.",
  "scripts": {
    "start": "node server/src/index.js",
    "dev": "node --watch server/src/index.js",
    "seed:large": "node server/src/db/seed-large-data.js",
    "test": "node --test --test-reporter=spec server/tests/*.test.js",
    "test:fuzz": "node --test --test-reporter=spec server/tests/fuzz.test.js",
    "test:tap": "node --test server/tests/*.test.js",
    "test:watch": "node --test --watch --test-reporter=spec server/tests/*.test.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "swagger-ui-express": "^5.0.1"
  }
}
