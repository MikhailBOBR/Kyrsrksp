{
  "name": "food-diary-app",
  "version": "1.0.0-rc.3",
  "private": true,
  "description": "Client-server food diary application with KБЖУ analytics.",
  "scripts": {
    "build": "npm run check:client",
    "start": "node server/src/cli.js server",
    "dev": "node --watch server/src/cli.js server",
    "config:check": "node server/src/cli.js config",
    "migrate": "node server/src/cli.js migrate",
    "create-admin": "node server/src/cli.js create-admin",
    "release": "npm run pre-release",
    "seed:demo": "node scripts/seed-readable-demo.js",
    "seed:large": "node server/src/db/seed-large-data.js",
    "check:client": "node scripts/check-client.js",
    "pre-release": "node scripts/pre-release.js",
    "test": "node --test --test-concurrency=1 --test-reporter=spec server/tests/*.test.js",
    "test:results": "node scripts/run-tests-with-table.js",
    "test:v8": "node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 --test-reporter=spec server/tests/*.test.js",
    "test:v8:raw": "npm run test:v8",
    "test:coverage": "npm run test:results && npm run test:surface && npm run test:v8",
    "test:fuzz": "node --test --test-concurrency=1 --test-reporter=spec server/tests/fuzz.test.js",
    "test:surface": "node scripts/generate-test-coverage-report.js --check",
    "test:full": "npm run check:client && npm run test:coverage",
    "test:tap": "node --test --test-concurrency=1 server/tests/*.test.js",
    "test:watch": "node --test --test-concurrency=1 --watch --test-reporter=spec server/tests/*.test.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "swagger-ui-express": "^5.0.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
