APP_ENV: development
RELEASE_VERSION: local-dev
SERVER_HOST: 0.0.0.0
SERVER_PORT: 8080
PORT: 8080
JWT_SECRET: change_me
DB_PROVIDER: sqlite
DB_PATH: ./server/data/app.db
DB_HOST: postgres
DB_PORT: 5432
DB_NAME: nutritrack
